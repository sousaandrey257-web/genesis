# ─── GENESIS environment ───────────────────────────────────────────
# Copy to .env and fill in. The web app reads these server-side only.

# Claude API (required — powers every agent)
ANTHROPIC_API_KEY=

# Deployment
VERCEL_TOKEN=

# Database / auth (Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Billing (Stripe)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# One recurring Price ID per plan (create them in the Stripe dashboard)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_AGENCY=

# Auth (NextAuth v5 / Auth.js)
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
# Public Supabase values for the browser client
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Competitor scraping (optional — falls back to model-only analysis if empty)
# ScrapingBee powers real competitor search + page scraping in CompetitorAgent.
SCRAPINGBEE_API_KEY=
# Legacy Tavily key (kept for the older WebScraper tool)
SCRAPING_API_KEY=

# Model selection (overridable)
GENESIS_CODER_MODEL=claude-sonnet-4-6
GENESIS_REASONING_MODEL=claude-sonnet-4-6
